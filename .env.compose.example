# Copy to `.env.compose` and adjust per deployment host.
# Docker Compose usage:
# docker compose --env-file .env.compose up -d --build

# Build contexts for sibling repos.
# Example for your server layout:
# EVBUDDY_BACKEND_CONTEXT=/srv/evbuddy/backend
# EVBUDDY_FRONTEND_CONTEXT=/srv/evbuddy/frontend
EVBUDDY_BACKEND_CONTEXT=../evbuddy-backend
EVBUDDY_FRONTEND_CONTEXT=../evbuddy-frontend

# Frontend build-time variables.
# Use an externally reachable API URL for your deployed frontend.
VITE_API_BASE_URL=https://exampleapi.com
VITE_MAPBOX_ACCESS_TOKEN=

# Backend runtime variables.
EV_BUDDY_ALLOWED_ORIGINS=https://evbuddy.diogomsmiranda.com,http://localhost:5173,http://127.0.0.1:5173
EV_BUDDY_DEFAULT_DISPLAY_HORIZON_MINUTES=20
EV_BUDDY_MAPBOX_GEOCODING_TOKEN=
EV_BUDDY_GEOCODING_COUNTRY=es
EV_BUDDY_GEOCODING_LANGUAGE=en
EV_BUDDY_GEOCODING_BBOX=2.052,41.320,2.228,41.470

# Basic API rate limiting.
EV_BUDDY_RATE_LIMIT_WINDOW_SECONDS=60
EV_BUDDY_RATE_LIMIT_STATIONS_PER_WINDOW=30
EV_BUDDY_RATE_LIMIT_GEOCODE_PER_WINDOW=20
EV_BUDDY_RATE_LIMIT_PREDICT_PER_WINDOW=10

# Optional ML/pipeline env.
EV_BUDDY_N_JOBS=2
MLFLOW_TRACKING_URI=
DVC_REMOTE_NAME=local
DVC_REMOTE_URL=
